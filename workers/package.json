{
  "name": "workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply novel-reader-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply novel-reader-db --remote"
  },
  "dependencies": {
    "hono": "^4.6.5",
    "jose": "^5.9.3",
    "cheerio": "1.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "wrangler": "^3.84.1",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "drizzle-orm": "^0.36.0",
    "drizzle-kit": "^0.28.0"
  }
}
