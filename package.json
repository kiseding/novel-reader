{
  "name": "novel-reader",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-user online novel reading platform powered by Cloudflare",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:workers": "pnpm --filter workers dev",
    "build:frontend": "pnpm --filter frontend build",
    "build:workers": "pnpm --filter workers build",
    "deploy:frontend": "pnpm --filter frontend deploy",
    "deploy:workers": "pnpm --filter workers deploy",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=18"
  }
}
